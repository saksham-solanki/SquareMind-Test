# SquareMind Environment Variables
# Copy this file to .env.local and fill in the values

# === Supabase ===
# From: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — NOT prefixed with NEXT_PUBLIC_
# From: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=

# === Analytics & Tracking ===
# From: Meta Events Manager > Data Sources > Your Pixel
NEXT_PUBLIC_META_PIXEL_ID=

# From: Google Analytics 4 > Admin > Data Streams > Measurement ID
NEXT_PUBLIC_GA4_ID=

# === Booking & Contact ===
# Your Calendly scheduling link (e.g. https://calendly.com/squaremind/strategy-call)
NEXT_PUBLIC_CALENDLY_URL=

# WhatsApp Business number with country code (e.g. 919876543210)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# === Site ===
# Production domain
NEXT_PUBLIC_SITE_URL=https://squaremind.in
